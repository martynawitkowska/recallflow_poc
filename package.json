{
  "name": "recallflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "vite --mode pages",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --mode pages",
    "check": "npm run build && npm run check:app-preferences && npm run check:api-key-storage && npm run check:ipc && npm run check:mnemonic-generation && npm run check:quiz-generation && npm run check:quiz-file && npm run check:quiz-schema && npm run check:quiz-answers && npm run check:quiz-results && npm run check:quiz-performance && npm run check:web-preview-storage && cargo fmt --check --manifest-path src-tauri/Cargo.toml && cargo check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:app-preferences": "node --no-warnings --experimental-strip-types src/lib/appPreferences.check.ts",
    "check:api-key-storage": "node --no-warnings --experimental-strip-types src/lib/apiKeyStorage.check.ts",
    "check:ipc": "node --no-warnings --experimental-strip-types src/lib/ipc.check.ts",
    "check:mnemonic-generation": "node --no-warnings --experimental-strip-types src/lib/mnemonicGeneration.check.ts",
    "check:quiz-file": "node --no-warnings --experimental-strip-types src/lib/readQuizFile.check.ts",
    "check:quiz-generation": "node --no-warnings --experimental-strip-types src/lib/quizGeneration.check.ts",
    "check:quiz-answers": "node --no-warnings --experimental-strip-types src/lib/quizAnswers.check.ts",
    "check:quiz-performance": "node --no-warnings --experimental-strip-types src/lib/quizPerformance.check.ts",
    "check:quiz-results": "node --no-warnings --experimental-strip-types src/lib/quizResults.check.ts",
    "check:quiz-schema": "node --no-warnings --experimental-strip-types src/lib/validateQuiz.check.ts",
    "check:web-preview-storage": "node --no-warnings --experimental-strip-types src/lib/webPreviewStorage.check.ts",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "preview": "vite preview",
    "preview:pages": "vite preview --mode pages",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
}
